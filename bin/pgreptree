#!/usr/bin/env python3
"""pgreptree — grep for processes, show their trees.

Matches a regex against all running process command lines, finds the
topmost (disjoint root) matches — i.e. matched processes whose ancestors
don't also match — and runs pstree on each one.
"""

import argparse
import concurrent.futures
import os
import re
import subprocess
import sys
from dataclasses import dataclass, field


# Matched against basename(exe) to detect interpreter-launched scripts, so that
# we also match/highlight argv[1] (the script path).
# We use exe rather than comm because comm is truncated to 15 chars and because
# comm is set to the *script* name (not the interpreter) for shebang scripts.
INTERPRETERS = re.compile(
    r'^(python[0-9.]*|bash|sh|dash|zsh|fish|perl[0-9.]*|ruby[0-9.]*'
    r'|node|deno|bun|Rscript|lua[0-9.]*|php[0-9.]*|java|tclsh[0-9.]*)$'
)


@dataclass(slots=True)
class Proc:
    pid: int
    ppid: int
    comm: str
    exe: str       # from /proc/pid/exe; resolves symlinks to the real ELF binary
    args: str
    # Candidate names to match patterns against, in priority order:
    # argv[0], exe, comm, then argv[1] (for interpreter scripts).
    # Each entry is a path (e.g. "/usr/bin/hg") or bare name (e.g. "hg").
    names: list[str] = field(default_factory=list)


# Regex to split out ANSI escape sequences to avoid mangling them
ANSI_RE = re.compile(
    r'('
    r'\x1b\[[\x30-\x3f]*[\x20-\x2f]*[\x40-\x7e]' # CSI: Controls colors, cursor, etc.
    r'|\x1b\][^\x07\x1b]*?(?:\x07|\x1b\\)' # OSC: OS Commands (titles, hyperlinks)
    r'|\x1b[\(\)][A-Za-z0-9]' # Charset selections (e.g., \x1b(B to reset to ASCII)
    r')'
)


def _match_name(name: str, pattern: re.Pattern[str], match_path: bool) -> bool:
    target = name if match_path else os.path.basename(name)
    return bool(pattern.search(target))


def highlight_args(args: str, pattern: re.Pattern[str], full: bool, match_path: bool,
                   names: list[str]) -> str:
    """Highlight pattern matches in the header line (=== PID ...: args ===)."""
    if full:
        return pattern.sub(r'\033[7m\g<0>\033[27m', args)

    for name in names:
        target = name if match_path else os.path.basename(name)
        if not pattern.search(target):
            continue

        idx = args.find(name)
        if idx == -1:
            bn = os.path.basename(name)
            idx = args.find(bn)
            if idx == -1:
                continue
            name = bn

        before = args[:idx]
        target = name if match_path else os.path.basename(name)
        target_start = idx if match_path else idx + len(name) - len(target)
        highlighted = pattern.sub(r'\033[7m\g<0>\033[27m', target)
        return args[:target_start] + highlighted + args[idx + len(name):]

    return args


def _apply_intervals(parts: list[str], intervals: list[tuple[int, int]]) -> str:
    res = []
    plain_idx = 0
    for i, part in enumerate(parts):
        if i % 2 != 0:
            res.append(part)
        else:
            for char in part:
                for strt, end in intervals:
                    if plain_idx == strt:
                        res.append('\033[7m')
                    if plain_idx == end:
                        res.append('\033[27m')
                res.append(char)
                plain_idx += 1
    for _, end in intervals:
        if plain_idx == end:
            res.append('\033[27m')
    return "".join(res)


def _splice_into_parts(parts: list[str], plain_pos: int, text: str) -> None:
    """Insert text (may contain ANSI codes) at a plain-text offset in parts."""
    char_count = 0
    for i in range(0, len(parts), 2):
        part_len = len(parts[i])
        if char_count + part_len >= plain_pos:
            split_at = plain_pos - char_count
            parts[i] = parts[i][:split_at] + text + parts[i][split_at:]
            return
        char_count += part_len


def highlight_pstree(stdout: str, pattern: re.Pattern[str], full: bool, match_path: bool, procs: dict[int, Proc]) -> str:
    out = []

    for line in stdout.splitlines(keepends=True):
        parts = ANSI_RE.split(line)
        plain_text = "".join(parts[::2])
        m = re.match(r'^([ \t│├└─]*)(.*?)(,\d+(?:,\d+)?)(.*)$', plain_text)
        
        if not m:
            if full:
                for i in range(0, len(parts), 2):
                    parts[i] = pattern.sub(r'\033[7m\g<0>\033[27m', parts[i])
            out.append("".join(parts))
            continue

        prefix, executable, pid_pgid, args_text = m.groups()
        pid = int(pid_pgid.split(',')[1])

        if full:
            for i in range(0, len(parts), 2):
                parts[i] = pattern.sub(r'\033[7m\g<0>\033[27m', parts[i])
            out.append("".join(parts))
            continue

        p = procs.get(pid)
        if not p:
            out.append("".join(parts))
            continue

        prefix_len = len(prefix)
        exec_len = len(executable)
        pid_len = len(pid_pgid)
        args_start = prefix_len + exec_len + pid_len
        intervals: list[tuple[int, int]] = []

        # pstree shows comm as the executable, but comm is truncated to 15 chars
        # (TASK_COMM_LEN). Find the longest name whose basename starts with the
        # displayed executable — that's the untruncated version we match against,
        # mapping highlight intervals back onto the truncated display.
        true_exec = executable
        true_exec_path = ""
        for name in p.names:
            bn = os.path.basename(name)
            if len(bn) >= len(executable) and bn[:len(executable)] == executable and len(bn) > len(true_exec):
                true_exec = bn
                true_exec_path = name[:-len(bn)] if "/" in name else ""

        if match_path:
            exec_target = true_exec_path + true_exec
            path_len = len(true_exec_path)
        else:
            exec_target = true_exec
            path_len = 0

        true_exec_len = len(true_exec)
        for mat in pattern.finditer(exec_target):
            s, e = mat.start() - path_len, mat.end() - path_len
            if s >= e or e <= 0:
                continue
            s = max(0, s)
            if s < true_exec_len and s < exec_len:
                intervals.append((prefix_len + s, prefix_len + min(min(e, true_exec_len), exec_len)))

        # For interpreter scripts, also highlight pattern matches within argv[1]
        # (the script path) in the args portion of the pstree line.
        argv = p.args.split()
        is_interp = (len(argv) > 1 and
                     INTERPRETERS.match(os.path.basename(p.exe if p.exe != "-" else "")))
        if is_interp:
            script_path = argv[1]
            if not script_path.startswith("-"):
                script_idx = args_text.find(script_path)
                if script_idx >= 0:
                    if match_path:
                        script_target = script_path
                        target_offset = 0
                    else:
                        script_bn = os.path.basename(script_path)
                        script_target = script_bn
                        target_offset = len(script_path) - len(script_bn)
                    for mat in pattern.finditer(script_target):
                        intervals.append((args_start + script_idx + target_offset + mat.start(),
                                          args_start + script_idx + target_offset + mat.end()))

        if intervals:
            out.append(_apply_intervals(parts, intervals))
        else:
            # The process matched (e.g. via argv[0]="python3") but nothing in
            # the pstree line is highlightable. Inject "[matched_name]" after
            # the pid to show why this process was included.
            # names ordering ensures argv[0] is preferred over exe.
            inject_name = None
            for name in p.names:
                if _match_name(name, pattern, match_path):
                    inject_name = os.path.basename(name)
                    break
            if inject_name:
                highlighted = pattern.sub(r'\033[7m\g<0>\033[27m', inject_name)
                _splice_into_parts(parts, args_start, f"[{highlighted}]")
            out.append("".join(parts))

    return "".join(out)


def parse_ps_output() -> dict[int, Proc]:
    proc = subprocess.Popen(
        ["ps", "--no-headers", "-ww", "-eo", "pid,ppid,comm,exe,args"],
        stdout=subprocess.PIPE, text=True,
    )
    stdout, _ = proc.communicate()
    if proc.returncode != 0:
        sys.exit(f"ps failed with exit code {proc.returncode}")

    procs: dict[int, Proc] = {}
    for line in stdout.splitlines():
        parts = line.split(None, 4)
        if len(parts) < 5:
            continue
        try:
            pid, ppid = int(parts[0]), int(parts[1])
            comm, exe, args = parts[2], parts[3], parts[4]
        except ValueError:
            continue
        # Some processes (e.g. Electron/Chromium children) report argv[0] as
        # /proc/self/exe instead of the real executable path.
        if args.startswith("/proc/self/exe"):
            args = comm + args.removeprefix("/proc/self/exe")

        # Build candidate names in priority order. A process can be known by
        # several names: argv[0] (what it was launched as), exe (real binary,
        # with symlinks resolved), comm (kernel name, often the script name for
        # shebang scripts), and argv[1] (the script path for interpreters).
        argv = args.split()
        names: list[str] = []
        seen: set[str] = set()

        for candidate in [argv[0] if argv else "", exe]:
            if not candidate or candidate == "-":
                continue
            if candidate not in seen:
                seen.add(candidate)
                names.append(candidate)

        if comm not in seen:
            seen.add(comm)
            names.append(comm)

        if len(argv) > 1 and INTERPRETERS.match(os.path.basename(exe if exe != "-" else argv[0])):
            script = argv[1]
            if not script.startswith("-") and script not in seen:
                seen.add(script)
                names.append(script)

        # bash -c "blaze run ..." / "bazel run ...": ps joins args with spaces
        # so argv[2] is just the first word of the command string.
        if (len(argv) >= 3 and os.path.basename(argv[0]) in ("bash", "sh")
                and argv[1] == "-c" and argv[2] in ("blaze", "bazel")
                and argv[2] not in seen):
            seen.add(argv[2])
            names.append(argv[2])

        procs[pid] = Proc(pid, ppid, comm, exe, args, names)
            
    procs.pop(proc.pid, None)
    return procs


def find_matches(procs: dict[int, Proc], pattern: re.Pattern[str], full: bool, match_path: bool) -> set[int]:
    my_pid = os.getpid()
    matched = set()
    for p in procs.values():
        if p.pid == my_pid:
            continue
            
        if full:
            if pattern.search(p.args):
                matched.add(p.pid)
        else:
            for name in p.names:
                if _match_name(name, pattern, match_path):
                    matched.add(p.pid)
                    break

    return matched


def disjoint_roots(procs: dict[int, Proc], matched: set[int]) -> list[int]:
    roots = []
    for pid in matched:
        cur = procs[pid].ppid
        while cur in procs:
            if cur in matched:
                break
            cur = procs[cur].ppid
        else:
            roots.append(pid)
    return sorted(roots)


def get_tree(pid: int, pattern: re.Pattern[str], full: bool, match_path: bool, procs: dict[int, Proc],
             ancestors: bool = False) -> str:
    cmd = ["pstree", "-hlUTg", "-C", "age", "-p", "--arguments"]
    if ancestors:
        cmd.append("-s")
    cmd.append(str(pid))
    res = subprocess.run(cmd, capture_output=True, text=True)

    return highlight_pstree(res.stdout, pattern, full, match_path, procs)


def main() -> None:
    parser = argparse.ArgumentParser(
        description="grep for processes, then show their trees",
    )
    parser.add_argument("pattern", help="regex to match against process names")
    parser.add_argument(
        "-i", "--ignore-case", action="store_true",
        help="case-insensitive matching (default is case-sensitive)",
    )
    parser.add_argument(
        "-w", "--word", action="store_true",
        help="match whole words only"
    )
    parser.add_argument(
        "-f", "--cmdline", action="store_true",
        help="match against full command line instead of just the executable name "
             "(implicitly enabled if pattern contains a space)"
    )
    parser.add_argument(
        "-x", "--exact", action="store_true",
        help="require an exact match of the executable (or full command line if -f)"
    )
    parser.add_argument(
        "-p", "--path", action="store_true",
        help="match against full executable path instead of basename "
             "(implicitly enabled if pattern contains '/')"
    )
    parser.add_argument(
        "-a", "--ancestors", action="store_true",
        help="show ancestor processes from init/systemd down to each match"
    )
    args = parser.parse_args()

    if " " in args.pattern:
        args.cmdline = True
    if "/" in args.pattern:
        args.path = True

    flags = re.IGNORECASE if args.ignore_case else 0
    
    pattern_str = args.pattern
    if args.word:
        pattern_str = rf"(?:\b|_)(?:{pattern_str})(?:\b|_)"
    if args.exact:
        pattern_str = rf"^(?:{pattern_str})$"
        
    try:
        pattern = re.compile(pattern_str, flags)
    except re.error as e:
        parser.error(f"bad regex: {e}")

    procs = parse_ps_output()
    matched = find_matches(procs, pattern, args.cmdline, args.path)
    if not matched:
        sys.exit(1)

    roots = disjoint_roots(procs, matched)
    
    with concurrent.futures.ThreadPoolExecutor() as executor:
        trees = list(executor.map(lambda p: get_tree(p, pattern, args.cmdline, args.path, procs, args.ancestors), roots))

    for i, (pid, tree) in enumerate(zip(roots, trees)):
        if i:
            print(flush=True)
        highlighted_args = highlight_args(procs[pid].args, pattern, args.cmdline, args.path, procs[pid].names)
        print(f"\033[1m=== PID {pid}: {highlighted_args} ===\033[0m", flush=True)
        sys.stdout.write(tree)
        sys.stdout.flush()


if __name__ == "__main__":
    try:
        main()
    except BrokenPipeError:
        sys.stderr.close()
        sys.exit(141)